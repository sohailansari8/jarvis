# ============================================================
#  JARVIS — Environment Variables Template
#  Copy this to .env and fill in your actual values.
#  This file IS safe to commit — it contains no real secrets.
# ============================================================

# ── AI Provider (choose one: gemini | openai | groq | ollama) ──
AI_PROVIDER=gemini

# ── Google Gemini ────────────────────────────────────────────
# Get free key → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── OpenAI (GPT-4o / GPT-4o-mini) ───────────────────────────
# Get key → https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

# ── Groq (free, ultra-fast Llama inference) ──────────────────
# Get free key → https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── Ollama (fully local, no key needed) ──────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3

# ── Feature flags ────────────────────────────────────────────
ENABLE_VISION=true
VISION_ALWAYS=false
CONVERSATION_MAX_TURNS=20
